        <validate-jwt header-name="Authorization" require-scheme="Bearer" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: Invalid or missing JWT token">
            <openid-config url="https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration" />
            <audiences>
                <audience>api://0f6db4af-332c-4fd5-b894-77fadb181e5c</audience>
            </audiences>
            <required-claims>
                <claim name="tid" match="any">
                    <!-- Microsoft corporate tenant ID -->
                    <value>72f988bf-86f1-41af-91ab-2d7cd011db47</value>
                </claim>
            </required-claims>
        </validate-jwt>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
