<policies>
    <inbound>
        <base />
        <choose>
            <when condition="@(context.Request.Url.Path.EndsWith(&quot;/health&quot;))">
            </when>
            <otherwise>
                <!-- Validate JWT - Microsoft tenant only, Azure Management audience -->
                <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: Invalid or missing JWT token" require-expiration-time="true" require-signed-tokens="true">
                    <openid-config url="https://login.microsoftonline.com/72f988bf-86f1-41af-91ab-2d7cd011db47/.well-known/openid-configuration" />
                    <audiences>
                        <audience>https://management.azure.com</audience>
                    </audiences>
                    <issuers>
                        <issuer>https://sts.windows.net/72f988bf-86f1-41af-91ab-2d7cd011db47/</issuer>
                        <issuer>https://login.microsoftonline.com/72f988bf-86f1-41af-91ab-2d7cd011db47/v2.0</issuer>
                    </issuers>
                </validate-jwt>
            </otherwise>
        </choose>
        <set-header name="X-Gateway-Secret" exists-action="override">
            <value>tea-earl-grey-hot-and-make-it-so</value>
        </set-header>
    </inbound>
    <backend>
        <forward-request timeout="240" />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
