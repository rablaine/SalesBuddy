{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "webAppName": {
      "type": "string",
      "defaultValue": "app-notehelper-ai"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "openaiEndpoint": {
      "type": "string",
      "defaultValue": "https://sharednotehelperendpoints.cognitiveservices.azure.com/"
    },
    "openaiDeployment": {
      "type": "string",
      "defaultValue": "gpt-4o-mini"
    },
    "openaiApiVersion": {
      "type": "string",
      "defaultValue": "2025-01-01-preview"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "defaultValue": ""
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[concat(parameters('webAppName'), '-plan')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', concat(parameters('webAppName'), '-plan'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', concat(parameters('webAppName'), '-plan'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "appCommandLine": "gunicorn --bind=0.0.0.0:8000 gateway:app",
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('openaiEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('openaiDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('openaiApiVersion')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('appInsightsConnectionString')]"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "webAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01', 'full').identity.principalId]"
    },
    "webAppHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName'))).defaultHostName]"
    }
  }
}
