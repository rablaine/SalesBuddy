<?xml version="1.0" encoding="UTF-8"?>

<!--
    Custom Action definitions for Sales Buddy MSI.

    Install: runs scripts/install.ps1 with all options enabled
    Uninstall: runs scripts/uninstall.ps1 -Silent

    Both use immediate type 34 (Directory + ExeCommand) custom actions.
    perUser scope means no elevation, so deferred is unnecessary.

    IMPORTANT: MSI type 34 does NOT format [Property] references in
    ExeCommand. It DOES expand %EnvironmentVariables%. So we use
    %LOCALAPPDATA% via cmd.exe /c to build the script path.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Fragment>

        <!-- ================================================================
             INSTALL: Run install.ps1 (prereqs, clone, server setup, shortcuts)
             Scheduled Before InstallFinalize so UI waits and shows progress.
             Files are on disk (InstallFiles already ran).
             ================================================================ -->

        <CustomAction Id="InstallAction"
                      Directory="INSTALLFOLDER"
                      ExeCommand="cmd.exe /c powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;%LOCALAPPDATA%\SalesBuddy\scripts\install.ps1&quot; -Shortcuts -DesktopShortcut -LaunchBrowser"
                      Return="check" />

        <!-- ================================================================
             UNINSTALL: Run uninstall.ps1 -Silent
             Scheduled Before RemoveFiles so the script still exists on disk.
             ================================================================ -->

        <CustomAction Id="UninstallAction"
                      Directory="INSTALLFOLDER"
                      ExeCommand="cmd.exe /c powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;%LOCALAPPDATA%\SalesBuddy\scripts\uninstall.ps1&quot; -Silent"
                      Return="ignore" />

        <!-- ================================================================
             Schedule custom actions in InstallExecuteSequence
             ================================================================ -->

        <InstallExecuteSequence>
            <Custom Action="InstallAction" Before="InstallFinalize" Condition="NOT REMOVE" />
            <Custom Action="UninstallAction" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
        </InstallExecuteSequence>

    </Fragment>

</Wix>
