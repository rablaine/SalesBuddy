<?xml version="1.0" encoding="UTF-8"?>

<!--
    Custom Action definitions for Sales Buddy MSI.

    Install: runs scripts/install.ps1 with all options enabled
    Uninstall: runs scripts/uninstall.ps1 -Silent

    Both use type 50 (Property + ExeCommand) deferred custom actions.
    The scripts are installed as File components by the MSI, so they
    exist on disk before the deferred actions run.

    Environment variable %LOCALAPPDATA% is used in ExeCommand because
    deferred actions cannot resolve MSI property references like
    [INSTALLFOLDER]. cmd.exe expands the env var at runtime.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Fragment>

        <!-- ================================================================
             INSTALL: Run install.ps1 (prereqs, clone, server setup, shortcuts)
             ================================================================ -->

        <!-- Set CustomActionData = path to cmd.exe (resolved during immediate phase) -->
        <SetProperty Id="InstallAction"
                     Value="[SystemFolder]cmd.exe"
                     Before="InstallAction"
                     Sequence="execute"
                     Condition="NOT REMOVE" />

        <!-- Deferred type 50: cmd.exe runs powershell with the bootstrap script -->
        <CustomAction Id="InstallAction"
                      Property="InstallAction"
                      ExeCommand="/c powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;%LOCALAPPDATA%\SalesBuddy\scripts\install.ps1&quot; -Shortcuts -DesktopShortcut -LaunchBrowser"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="check" />

        <!-- ================================================================
             UNINSTALL: Run uninstall.ps1 -Silent
             ================================================================ -->

        <SetProperty Id="UninstallAction"
                     Value="[SystemFolder]cmd.exe"
                     Before="UninstallAction"
                     Sequence="execute"
                     Condition="REMOVE=&quot;ALL&quot;" />

        <CustomAction Id="UninstallAction"
                      Property="UninstallAction"
                      ExeCommand="/c powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;%LOCALAPPDATA%\SalesBuddy\scripts\uninstall.ps1&quot; -Silent"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="ignore" />

        <!-- ================================================================
             Schedule custom actions in InstallExecuteSequence
             ================================================================ -->

        <InstallExecuteSequence>
            <Custom Action="InstallAction" After="InstallFiles" Condition="NOT REMOVE" />
            <Custom Action="UninstallAction" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
        </InstallExecuteSequence>

    </Fragment>

</Wix>
