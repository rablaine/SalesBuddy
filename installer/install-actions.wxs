<?xml version="1.0" encoding="UTF-8"?>

<!--
    Custom Action definitions for Sales Buddy MSI.

    Uses C# DTF (Deployment Tools Foundation) custom action DLLs instead of
    external .cmd scripts. This gives us:
      - No terminal windows during install
      - Real-time status text updates on the MSI progress page
      - Progress bar advancement as each step completes

    The DLL runs inside the MSI engine process. Deferred actions use
    CustomActionData to receive properties from the immediate "setter" actions.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Fragment>

        <!-- The custom action DLL, embedded in the MSI as a binary stream -->
        <Binary Id="CustomActionsDll"
                SourceFile="SalesBuddy.CustomActions\bin\Release\net451\SalesBuddy.CustomActions.CA.dll" />

        <!-- ================================================================
             INSTALL: Set properties then run the deferred install action.
             The setter runs as immediate (can read session properties).
             The action runs as deferred (can only read CustomActionData).
             ================================================================ -->

        <CustomAction Id="SetInstallActionData"
                      Property="InstallAction"
                      Value="INSTALLFOLDER=[INSTALLFOLDER];STARTMENUSHORTCUT=[STARTMENUSHORTCUT];DESKTOPSHORTCUT=[DESKTOPSHORTCUT];AUTOSTART=[AUTOSTART]" />

        <CustomAction Id="InstallAction"
                      BinaryRef="CustomActionsDll"
                      DllEntry="InstallAction"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="check" />

        <!-- ================================================================
             UNINSTALL: Set properties then run the deferred uninstall action.
             ================================================================ -->

        <CustomAction Id="SetUninstallActionData"
                      Property="UninstallAction"
                      Value="INSTALLFOLDER=[INSTALLFOLDER]" />

        <CustomAction Id="UninstallAction"
                      BinaryRef="CustomActionsDll"
                      DllEntry="UninstallAction"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="ignore" />

        <!-- ================================================================
             Schedule custom actions in InstallExecuteSequence.
             Setters run immediately (Before their deferred counterpart).
             Install runs After InstallFiles (icon.ico is on disk).
             Uninstall runs Before RemoveFiles (app files still accessible).
             ================================================================ -->

        <!-- ================================================================
             LAUNCH: Immediate action triggered from the Exit dialog
             checkbox. Reads INSTALLFOLDER to find the .env port.
             ================================================================ -->

        <CustomAction Id="LaunchApp"
                      BinaryRef="CustomActionsDll"
                      DllEntry="LaunchApp"
                      Execute="immediate"
                      Impersonate="yes"
                      Return="ignore" />

        <InstallExecuteSequence>
            <Custom Action="SetInstallActionData" Before="InstallAction" Condition="NOT REMOVE" />
            <Custom Action="InstallAction" After="InstallFiles" Condition="NOT REMOVE" />
            <Custom Action="SetUninstallActionData" Before="UninstallAction" Condition="REMOVE=&quot;ALL&quot;" />
            <Custom Action="UninstallAction" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
        </InstallExecuteSequence>

    </Fragment>

</Wix>
