<?xml version="1.0" encoding="UTF-8"?>

<!--
    Sales Buddy MSI Installer
    WiX v4 / WiX SDK 5.x

    This MSI installs Sales Buddy using C# DTF custom actions that:
      1. Install prerequisites (git, python, az cli, node) with live status text
      2. Clone the repo, set up venv, install deps, run migrations
      3. Create shortcuts, register auto-start, launch the server
      4. Register in Add/Remove Programs for clean uninstall

    No terminal windows appear during installation. The MSI progress page
    shows real-time status text as each step runs.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Package Name="Sales Buddy"
             Manufacturer="Sales Buddy Contributors"
             Version="1.0.0"
             UpgradeCode="f3a7c2d1-8e4b-4f9a-b6c5-1d2e3f4a5b6c"
             Scope="perUser"
             InstallerVersion="500">

        <SummaryInformation Description="Sales Buddy - Your Azure sales companion" />

        <!-- Embed cabinet into MSI so it's a single file -->
        <MediaTemplate EmbedCab="yes" />

        <!-- Upgrade: remove previous versions before install -->
        <MajorUpgrade DowngradeErrorMessage="A newer version of Sales Buddy is already installed." />

        <!-- Icon for Add/Remove Programs -->
        <Icon Id="SalesBuddyIcon" SourceFile="..\static\icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="SalesBuddyIcon" />
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/rablaine/SalesBuddy" />
        <Property Id="ARPNOREPAIR" Value="yes" />
        <Property Id="ARPNOMODIFY" Value="yes" />

        <!-- Default values for install options -->
        <Property Id="STARTMENUSHORTCUT" Value="1" />
        <Property Id="DESKTOPSHORTCUT" Value="1" />
        <Property Id="AUTOSTART" Value="1" />

        <!-- Exit dialog: "Launch Sales Buddy" checkbox (checked by default) -->
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Sales Buddy" />

        <!-- Custom UI: Welcome -> License -> Options -> Progress -> Finish -->
        <UIRef Id="SalesBuddyUI" />
        <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
        <WixVariable Id="WixUIBannerBmp" Value="Banner.bmp" />
        <WixVariable Id="WixUIDialogBmp" Value="Dialog.bmp" />

        <!-- Install icon + registry marker to INSTALLFOLDER.
             The DTF custom action handles everything else (clone, prereqs, etc.) -->
        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="INSTALLFOLDER" Name="SalesBuddy">
                <Component Id="AppIcon" Guid="f6a7b8c9-d0e1-2345-6789-abcdef012345">
                    <File Id="IconFile" Source="..\static\icon.ico" KeyPath="yes" />
                </Component>
                <Component Id="Marker" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
                    <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
                    <RegistryValue Root="HKCU"
                                   Key="Software\SalesBuddy"
                                   Name="Installed"
                                   Type="integer"
                                   Value="1"
                                   KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <Feature Id="Main" Title="Sales Buddy" Level="1">
            <ComponentRef Id="Marker" />
            <ComponentRef Id="AppIcon" />
        </Feature>

        <!-- Pull in custom actions from install-actions.wxs -->
        <CustomActionRef Id="InstallAction" />
        <CustomActionRef Id="UninstallAction" />

    </Package>

</Wix>
