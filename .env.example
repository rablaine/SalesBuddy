# Database Configuration (SQLite - single file database)
DATABASE_URL=sqlite:///data/notehelper.db

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production
FLASK_DEBUG=False

# Application Settings
APP_NAME=NoteHelper

# Server port (used by deploy scripts)
# Default Flask development port is 5000
PORT=5000

# Single-User Local Deployment
# No authentication required - app runs in single-user mode

# Azure OpenAI Configuration (optional - enables AI features)
# See README.md for setup instructions

# Option 1: APIM Gateway (recommended)
# Routes all AI calls through a centralized APIM → App Service → Azure OpenAI pipeline.
# Set this URL and ensure you are logged into 'az login' with a Microsoft account.
# AI_GATEWAY_URL=https://apim-notehelper.azure-api.net/ai

# Option 2: Direct Azure OpenAI (legacy — requires service principal)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Service Principal (required for AI and MSX features)
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Scheduled Milestone Sync (optional)
# Set to an hour (0-23) to auto-sync milestones daily at that time
# Example: MILESTONE_SYNC_HOUR=3  (syncs at 3:00 AM)
# MILESTONE_SYNC_HOUR=
